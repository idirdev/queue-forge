{
  "name": "queue-forge",
  "version": "1.0.0",
  "description": "In-memory job queue processor with priorities, retries, and concurrency control",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "example:basic": "ts-node examples/basic.ts",
    "example:priority": "ts-node examples/priority.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "queue",
    "job",
    "worker",
    "priority",
    "retry",
    "concurrency",
    "scheduler",
    "typescript"
  ],
  "author": "idirdev",
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7"
  }
}
